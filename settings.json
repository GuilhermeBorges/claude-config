{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git worktree*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(ls*)",
      "Bash(bun install*)",
      "Bash(bun run build*)",
      "Bash(bun run test*)",
      "Bash(bun run lint*)",
      "Bash(bun run check*)",
      "Bash(bun run dev*)",
      "Bash(bunx biome*)",
      "Bash(bunx tsup*)",
      "Bash(bun publish*)"
    ]
  },
  "env": {
    "WORKTREE_DIR": ".worktrees"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task completed\" with title \"Claude Code\"' 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Compaction starting — if there is anything important to preserve in the summary, mention it in your next message.\"}'",
            "statusMessage": "Notifying before compact..."
          }
        ]
      }
    ]
  }
}
